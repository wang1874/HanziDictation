{
  "expo": {
    "name": "汉字听写",
    "slug": "HanziDictation",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.svg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "hanzidictation",
    "splash": {
      "image": "./assets/icon.svg",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8E7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.hanzidictation"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.svg",
        "backgroundColor": "#FFF8E7"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.example.hanzidictation"
    },
    "web": {
      "favicon": "./assets/icon.svg",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
